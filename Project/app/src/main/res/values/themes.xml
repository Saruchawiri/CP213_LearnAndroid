<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Project" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- Use our doodle logo for the splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <!-- Set the theme to switch to once the splash screen is dismissed -->
        <item name="postSplashScreenTheme">@style/Theme.Project</item>
    </style>
</resources>